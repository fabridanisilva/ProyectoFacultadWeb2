doctype html
html(lang="es")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title= title
        //- bootstrap
        link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css", rel="stylesheet")
    body
    //- este es el nav o barra de navegacion
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
        div.container
            a.navbar-brand(href="/") Proyect
            button.navbar-toggler(type="button", data-bs-toggle="collapse", data-bs-target="#navbarNav")
                span.navbar-toggler-icon
            div.collapse.navbar-collapse#navbarNav
                ul.navbar-nav.ms-auto
                    li.nav-item
                        a.nav-link(href="/") Inicio
                    //- si hay un usuario conectado, mostramos su nombre y botón de salir
                    if usuarioActual
                        li.nav-item
                            a.nav-link(href="/publicaciones/nueva") Crear Publicación
                        li.nav-item
                        span.nav-link.text-warning ¡Hola, #{usuarioActual.username}!
                        li.nav-item
                            a.nav-link(href="/logout") Cerrar Sesión
                    //- Si no hay usuario conectado, mostramos registro y login
                    else
                        li.nav-item
                        a.nav-link(href="/registro") Registrarse
                        li.nav-item
                            a.nav-link(href="/login") Iniciar Sesión

    //- en este contenedor se va a ver las publicaciones
    div.container.mt-5
        block content

    //- con esto integramos boostrap
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js")